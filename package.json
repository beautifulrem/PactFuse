{
  "name": "pactfuse",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "build:contracts": "forge build",
    "test:contracts": "forge test",
    "export-deployment-registry": "pnpm --filter @pactfuse/evidence-schema build && pnpm --filter @pactfuse/api export-deployment-registry",
    "live-smoke": "node scripts/live-smoke.mjs",
    "verify-live-artifacts": "node scripts/verify-live-artifacts.mjs",
    "dev:api": "pnpm --filter @pactfuse/api dev",
    "start:api": "pnpm --filter @pactfuse/api start"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "tsx": "^4.21.0",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
